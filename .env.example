# .env.example

# This file is a template for the environment variables required for the application.

# The endpoint for Formspree, used to handle form submissions.
# Replace with your own endpoint:
FORMSPREE_ENDPOINT=https://formspree.io/YOUR_ENDPOINT_HERE

# The URL for Supabase, the open-source Firebase alternative.
# Replace with your Supabase project URL:
SUPABASE_URL=https://your-project.supabase.co

# The anonymous key for Supabase, required for client-side access.
# Replace with your Supabase anon key:
SUPABASE_ANON_KEY=your-anon-key-here
